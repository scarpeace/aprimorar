{
  // OpenCode workspace runtime settings.
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.4",

  // Permission controls replace the older approval config.
  "permission": {
    "*": "allow",
    "bash": "ask",
    "edit": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },

  // Legacy tool toggles are still supported, but permission is preferred.
  "tools": {
    "bash": true,
    "read": true,
    "write": true,
    "edit": true,
    "webfetch": true
  },

  "share": "manual",
  "autoupdate": "notify"
}
