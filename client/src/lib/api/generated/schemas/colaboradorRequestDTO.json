{
  "required": [
    "cpf",
    "dataNascimento",
    "email",
    "endereco",
    "funcao",
    "nome",
    "pix",
    "telefone"
  ],
  "type": "object",
  "properties": {
    "nome": {
      "minLength": 1,
      "type": "string",
      "description": "Nome completo do colaborador",
      "example": "João Pereira"
    },
    "dataNascimento": {
      "type": "string",
      "description": "Data de nascimento do colaborador",
      "format": "date",
      "example": "1990-05-21"
    },
    "pix": {
      "minLength": 1,
      "type": "string",
      "description": "Chave PIX do colaborador",
      "example": "joao.pereira@example.com"
    },
    "telefone": {
      "minLength": 1,
      "type": "string",
      "description": "Telefone de contato do colaborador",
      "example": "(61) 99999-9999"
    },
    "cpf": {
      "minLength": 1,
      "type": "string",
      "description": "CPF do colaborador",
      "example": "123.456.789-00"
    },
    "email": {
      "minLength": 1,
      "type": "string",
      "description": "E-mail do colaborador",
      "example": "joao.pereira@example.com"
    },
    "funcao": {
      "type": "string",
      "description": "Função/Papel do funcionário",
      "example": "PROFESSOR",
      "enum": ["PROFESSOR", "ADMINISTRATIVO", "TERAPEUTA", "MENTOR"]
    },
    "endereco": {
      "required": ["bairro", "cep", "cidade", "estado", "numero", "rua"],
      "type": "object",
      "properties": {
        "rua": {
          "minLength": 1,
          "type": "string",
          "description": "Rua",
          "example": "Avenida Paulista"
        },
        "numero": {
          "minLength": 1,
          "type": "string",
          "description": "Número",
          "example": "1000"
        },
        "complemento": {
          "type": "string",
          "description": "Complemento",
          "nullable": true,
          "example": "Sala 101"
        },
        "bairro": {
          "minLength": 1,
          "type": "string",
          "description": "Bairro",
          "example": "Bela Vista"
        },
        "cidade": {
          "minLength": 1,
          "type": "string",
          "description": "Cidade",
          "example": "São Paulo"
        },
        "estado": {
          "maxLength": 2,
          "minLength": 2,
          "type": "string",
          "description": "UF",
          "example": "SP"
        },
        "cep": {
          "minLength": 1,
          "pattern": "^\\d{8}$",
          "type": "string",
          "description": "CEP sem pontuação",
          "example": "01310000"
        }
      },
      "description": "Endereço do cadastro",
      "x-readme-ref-name": "EnderecoRequestDTO"
    }
  },
  "description": "Formato de payload para criar um novo colaborador",
  "x-readme-ref-name": "ColaboradorRequestDTO"
}
