{
  "required": ["cpf", "createdAt", "email", "id", "nome", "telefone"],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID do responsável",
      "format": "uuid",
      "example": "123e4567-e89b-12d3-a456-426614174000"
    },
    "nome": {
      "type": "string",
      "description": "Nome do responsável",
      "example": "João Silva"
    },
    "dataNascimento": {
      "type": "string",
      "description": "Data de nascimento do responsável",
      "format": "date",
      "nullable": true,
      "example": "1990-01-01"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do responsável",
      "example": "12345678901"
    },
    "telefone": {
      "type": "string",
      "description": "Contato do responsável",
      "example": "11999999999"
    },
    "email": {
      "type": "string",
      "description": "Email do responsável",
      "example": "email@email.com"
    },
    "createdAt": {
      "type": "string",
      "description": "Data e hora quando o responsável foi criado",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "Data e hora quando o responsável foi atualizado",
      "format": "date-time",
      "nullable": true
    }
  },
  "description": "Dados do responsável retornados pela API",
  "x-readme-ref-name": "ResponsavelResponseDTO"
}
