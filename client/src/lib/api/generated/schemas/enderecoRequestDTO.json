{
  "required": ["bairro", "cep", "cidade", "estado", "numero", "rua"],
  "type": "object",
  "properties": {
    "rua": {
      "minLength": 1,
      "type": "string",
      "description": "Rua",
      "example": "Avenida Paulista"
    },
    "numero": {
      "minLength": 1,
      "type": "string",
      "description": "Número",
      "example": "1000"
    },
    "complemento": {
      "type": "string",
      "description": "Complemento",
      "nullable": true,
      "example": "Sala 101"
    },
    "bairro": {
      "minLength": 1,
      "type": "string",
      "description": "Bairro",
      "example": "Bela Vista"
    },
    "cidade": {
      "minLength": 1,
      "type": "string",
      "description": "Cidade",
      "example": "São Paulo"
    },
    "estado": {
      "maxLength": 2,
      "minLength": 2,
      "type": "string",
      "description": "UF",
      "example": "SP"
    },
    "cep": {
      "minLength": 1,
      "pattern": "^\\d{8}$",
      "type": "string",
      "description": "CEP sem pontuação",
      "example": "01310000"
    }
  },
  "description": "Endereço do cadastro",
  "x-readme-ref-name": "EnderecoRequestDTO"
}
