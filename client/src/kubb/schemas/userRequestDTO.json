{
  "required": ["password", "role", "username"],
  "type": "object",
  "properties": {
    "username": {
      "minLength": 1,
      "type": "string",
      "description": "E-mail usado no login",
      "example": "usuario@aprimorar.local"
    },
    "password": {
      "maxLength": 2147483647,
      "minLength": 6,
      "type": "string",
      "description": "Senha",
      "example": "password123"
    },
    "role": {
      "type": "string",
      "description": "Perfil de acesso",
      "example": "EMPLOYEE",
      "enum": ["STUDENT", "EMPLOYEE", "PARENT", "ADMIN"]
    }
  },
  "description": "Payload para criação de usuário",
  "x-readme-ref-name": "UserRequestDTO"
}
