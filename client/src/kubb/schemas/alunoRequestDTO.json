{
  "required": [
    "cpf",
    "dataNascimento",
    "email",
    "endereco",
    "escola",
    "nome",
    "responsavelId",
    "telefone"
  ],
  "type": "object",
  "properties": {
    "nome": {
      "minLength": 1,
      "type": "string",
      "description": "Nome completo do aluno",
      "example": "Ana Silva"
    },
    "dataNascimento": {
      "type": "string",
      "description": "Data de nascimento do aluno",
      "format": "date",
      "example": "2000-01-01"
    },
    "cpf": {
      "minLength": 1,
      "type": "string",
      "description": "CPF do aluno",
      "example": "123.456.789-00"
    },
    "escola": {
      "minLength": 1,
      "type": "string",
      "description": "Escola do aluno",
      "example": "Colégio Aprimorar"
    },
    "telefone": {
      "minLength": 1,
      "type": "string",
      "description": "Contato do aluno",
      "example": "(61) 99999-9999"
    },
    "email": {
      "minLength": 1,
      "type": "string",
      "description": "E-mail do aluno",
      "example": "ana.silva@example.com"
    },
    "endereco": {
      "type": "object",
      "properties": {
        "rua": { "type": "string" },
        "numero": { "type": "string" },
        "bairro": { "type": "string" },
        "cidade": { "type": "string" },
        "estado": { "type": "string" },
        "cep": { "type": "string" },
        "complemento": { "type": "string" }
      },
      "description": "Endereço do aluno",
      "x-readme-ref-name": "EnderecoRequestDTO"
    },
    "responsavelId": {
      "type": "string",
      "description": "ID do responsável vinculado ao aluno",
      "format": "uuid"
    }
  },
  "description": "Formato de payload para o cadastro de um aluno",
  "x-readme-ref-name": "AlunoRequestDTO"
}
