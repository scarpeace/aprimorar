{
  "name": "@kubb/react-fabric",
  "version": "0.13.3",
  "description": "React integration for Kubb's fabric - JSX runtime and component-based code generation with React reconciler for building type-safe generators",
  "keywords": [
    "react",
    "jsx",
    "jsx-runtime",
    "react-reconciler",
    "component-generation",
    "codegen",
    "code-generator",
    "typescript",
    "file-generation",
    "plugin-system",
    "plugins",
    "fabric",
    "kubb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/fabric.git",
    "directory": "packages/react-fabric"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "sideEffects": [
    "./dist/globals.js",
    "./dist/globals.cjs"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./globals": {
      "import": "./dist/globals.js",
      "require": "./dist/globals.cjs"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./parsers": {
      "import": "./dist/parsers.js",
      "require": "./dist/parsers.cjs"
    },
    "./plugins": {
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "globals": [
        "./dist/globals.d.ts"
      ],
      "jsx-dev-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "jsx-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "parsers": [
        "./dist/parsers.d.ts"
      ],
      "plugins": [
        "./dist/plugins.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "dist",
    "*.d.ts",
    "*.d.cts",
    "!*.map",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "size-limit": [
    {
      "path": "./dist/*.js",
      "limit": "510 KiB",
      "gzip": true
    }
  ],
  "dependencies": {
    "react-devtools-core": "6.1.5",
    "remeda": "^2.33.6",
    "ws": "8.18.0",
    "@kubb/fabric-core": "0.13.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "0.32.0",
    "@types/ws": "^8.18.1",
    "react": "19.2.3",
    "react-reconciler": "0.33.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown && size-limit",
    "clean": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "lint": "pnpm biome lint .",
    "lint:fix": "pnpm biome lint --fix --unsafe .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check -tag canary",
    "start": "tsdown --watch ./src",
    "start:devtools": "npx react-devtools",
    "test": "vitest --passWithNoTests",
    "test:devtools": "node ./dist/runner.cjs",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  }
}