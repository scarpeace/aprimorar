// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // AI e agentes
  "disable_ai": false,
  "agent": {
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
      "enable_thinking": false
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "google",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": true
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "favorite_models": [
        "google/gemini-3-pro-preview/low",
        "google/gemini-3-pro-preview/high",
        "google/gemini-3.1-flash-lite-preview",
        "opencode/minimax-m2.5-free",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4"
      ]
    }
  },
  "context_servers": {
    "mcp-server-brave-search": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 15.0,

  // Atualizacao e comportamento geral
  "auto_update": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 10000
    }
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "base_keymap": "VSCode",
  "session": {
    "trust_all_worktrees": true
  },

  // Editor
  "format_on_save": "off",
  "auto_indent": "none",
  "auto_indent_on_paste": false,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 200,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "cursor_blink": true,
  // "show_completions_on_input": false,
  // "show_edit_predictions": false,

  // Linguagens e LSP
  "file_scan_inclusions": [
    ".env*",
    "docker-compose.*.yml",
    // "src/kubb"
  ],
  "languages": {
    "TypeScript": {
      "code_actions_on_format": {
        "source.addMissingImports.ts": true
      }
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
            "formatter": "prettier",
            "bracketSameLine": true
          }
        },
        "jdtls": {
          "settings": {
            "java_home": "/usr/lib/jvm/java-21-openjdk-amd64",
            "lombok_support": true,
            "check_updates": "always"
          },
          "initialization_options": {
            "bundles": [],
            "workspaceFolders": [
              "file:///src/main/java"
            ],
            "settings": {
              "java": {
                "home": "/usr/lib/jvm/java-21-openjdk-amd64",
                "configuration": {
                  "updateBuildConfiguration": "automatic"
                },
                "import": {
                  "maven": {
                    "enabled": true
                  },
                  "gradle": {
                    "enabled": true
                  }
                },
                "format": {
                  "enabled": true
                }
              }
            }
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "prettier": {
    "printWidth": 140
  },

  // Aparencia
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Catppuccin Frappé"
  },
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato"
  },
  "title_bar": {
    "show_project_items": false,
    "show_branch_name": false
  },
  "toolbar": {
    "quick_actions": false
  },
  "gutter": {
    "min_line_number_digits": 0
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "git_status": false
  },

  // Tipografia
  "ui_font_family": ".ZedMono",
  "ui_font_size": 14.0,
  "ui_font_weight": 400.0,
  "buffer_font_family": "Anonymous Pro",
  "buffer_font_size": 15.0,
  "buffer_font_weight": 450.0,
  "buffer_line_height": "comfortable",

  // Terminal
  "terminal": {
    "default_height": 330.0,
    "cursor_shape": "bar",
    "font_family": "monospace",
    "font_size": 13.0,
    "font_weight": 400.0,
    "blinking": "on",
    "env": {}
  }
}
